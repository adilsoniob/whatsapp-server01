# Nunca coloque senhas reais aqui se este arquivo for compartilhado.
# Copie para .env e preencha localmente.

PORT=3000
# Host/interface que o Node vai escutar.
# - Local/VPS atrás do Nginx: 127.0.0.1 (recomendado)
# - Rede local (LAN): 0.0.0.0
HOST=127.0.0.1
SMS_ROTATION_LIMIT=10
SMS_PROVIDER_MODE=mock

# Webhook externo (para chamar sem login/cookies, ex: automacoes/servidor).
# Use no header: x-api-key: <sua-chave>
WEBHOOK_API_KEY=
# Opcional: restringe as contas usadas quando selectedAccounts nao for enviado (separe por virgula).
WEBHOOK_DEFAULT_ACCOUNTS=

# Quando a plataforma fornecer API, altere SMS_PROVIDER_MODE=api e preencha:
SMS_API_URL=
SMS_API_METHOD=POST
SMS_API_AUTH_MODE=body
SMS_API_ACCOUNT_FIELD=account
SMS_API_PASSWORD_FIELD=password
SMS_API_PHONE_FIELD=phone
SMS_API_MESSAGE_FIELD=message
SMS_API_SUCCESS_PATH=

# Contas autorizadas para envio. Use o mesmo padrao para quantas contas precisar.
SMS_PASSWORD_1=KaA6Q1ch
SMS_ACCOUNT_2=0122C371B
SMS_PASSWORD_2=U5fLM1q9
SMS_ACCOUNT_3=0122C371C
SMS_PASSWORD_3=Po1Mw8UZ
SMS_ACCOUNT_4=0122C371D
SMS_PASSWORD_4=I73i8twW
SMS_SMPP_PASSWORD_1=57Sv#Vg|-
SMS_SMPP_PASSWORD_2=A9{^8?Gl
SMS_SMPP_PASSWORD_3=oe{L1Hq
SMS_SMPP_PASSWORD_4=^Slj!a9Z
# SMPP: use SMS_PROVIDER_MODE=smpp para envio real via SMPP.
SMPP_HOST=
SMPP_PORT=2775
SMPP_SECURE=false
SMPP_BIND_MODE=transceiver
SMPP_SYSTEM_TYPE=
SMPP_INTERFACE_VERSION=52
SMPP_SOURCE_ADDR=
SMPP_SOURCE_ADDR_TON=0
SMPP_SOURCE_ADDR_NPI=0
SMPP_DEST_ADDR_TON=1
SMPP_DEST_ADDR_NPI=1
SMPP_REGISTERED_DELIVERY=1
SMPP_ENQUIRE_LINK_INTERVAL_MS=30000
SMPP_TIMEOUT_MS=15000


# Painel web: usa login/senha do painel e envia via endpoint interno do site.
PANEL_BASE_URL=https://msg.topying.net
PANEL_SENDER_ID=
PANEL_TIMEOUT_MS=20000
