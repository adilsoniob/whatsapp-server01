 	function exportSearchDataRequest(tableId, url, exportBtnObj){
        loadToken();
        var loadInx = layer.load(2);
        btnDisabledOrEnable(exportBtnObj.id, false,"darkorange");
	    var formData = new FormData();
	    formData.append("token",window.token);
	    var queryParams = getSearchParams(tableId);
	    for (var key in queryParams){ 
		   formData.append(key, queryParams[key]);
	    }
	    var xhr = new XMLHttpRequest();
	    xhr.responseType = "blob";
	    xhr.onprogress = (event) => {
			if (event.lengthComputable) {
				const percentComplete = (event.loaded / event.total) * 100;
				console.log(percentComplete.toFixed(2) + '%');
			}
		 };
	    xhr.onload = function () {
		   layer.close(loadInx);
           if (this.status == "200") {
               var fn = dateFtt("yy_MMdd_hhmmss_",new Date()) + Math.floor(Math.random()*10)+".xlsx";
               var blob = this.response;
               var aElem = document.createElement('a');
               aElem.href = window.URL.createObjectURL(blob);
               aElem.download = fn;
               aElem.onload = function (e) {
                   window.URL.revokeObjectURL(aElem.href);
               };
               $("body").append(aElem);
               aElem.click();
               $(aElem).remove();
               btnDisabledOrEnable(exportBtnObj.id, true, "darkorange");
            }
        };
	    xhr.open("post", url, true);
	    xhr.send(formData);
 	}
 	
