   function generatePwdString(minLength = 8, maxLength = 32, special = true) {
	    // 确保长度在有效范围内
	    const length = Math.max(minLength, Math.min(maxLength, Math.floor(Math.random() * (maxLength - minLength + 1)) + minLength));
	    
	    // 定义字符集
	    const letters = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ';
	    const digits = '0123456789';
	    const special_chars = '~@#%^$?&*%:!|-{.}!';
	    let allChars = letters + digits;
	    if(special){
	    	allChars += special_chars;
	    }
	    // 初始化结果数组
	    let result = [];
	    
	    // 确保至少有一个字母和一个数字
	    result.push(letters.charAt(Math.floor(Math.random() * letters.length)));
	    result.push(digits.charAt(Math.floor(Math.random() * digits.length)));
	    
	    // 填充剩余字符
	    const remainingLength = length - 2;
	    for (let i = 0; i < remainingLength; i++) {
	        result.push(allChars.charAt(Math.floor(Math.random() * allChars.length)));
	    }
	    
	    // 打乱顺序以确保随机性
	    for (let i = result.length - 1; i > 0; i--) {
	        const j = Math.floor(Math.random() * (i + 1));
	        [result[i], result[j]] = [result[j], result[i]];
	    }
	    
	    return result.join('');
	}
   
