    function getSubmitData(tableId, type, isBulkEdit){
    	var param = {};
    	var tableLocal = getLocalStorageModel(tableId, "tableParams");
    		tableItems = tableLocal.trs,
	    	itemsLen = tableItems.length,
	    	tableKey = tableLocal.tableKey,
	    	type = $("#"+tableId+"-editAddType").val(),
	    	tableKeyVal = "";
    	for(var i=0; i<itemsLen; i++){
    		var item = tableItems[i],
    			name = item.name,
    			hideEdit = item.hideEdit,
    			rangeIpt = item.rangeIpt;
    		if(isBulkEdit && !item.bulkEdit){
    			continue;
    		}
			if(!isBulkEdit && hideEdit && (hideEdit=="A"||(hideEdit=="E" && type=="edit")||(hideEdit=="N" && type=="new")))
				continue;
			if((item.timeLimit && item.iptTime) || item.vali.laydate){// || item.vali.date
				var startTimeName = "";
			    var endTimeName = "";
			    
			    if(item.timeLimit){
			    	var timeLimit = item.timeLimit;
			    	startTimeName = timeLimit[0];
				    endTimeName = timeLimit[1];
			    }
			    
			    var beginTimeval = "";
				var endTimeval = "";
				
				if(item.vali.laydate){ //单个输入框，天，周范围，指定月，
					startTimeName = 'beginTime';
			    	endTimeName = 'endTime';
					var timeVal = $("#edit-"+ tableId + "-"+name).val();
					if(timeVal){
						if(item.vali.laytype == "month"){
							beginTimeval+= timeVal+"-01 00:00:00";
							endTimeval  += getlastDate(timeVal)+" 23:59:59";
						}else if(item.vali.laytype == "week"){
							var times = timeVal.split("~");
							beginTimeval+= times[0]+" 00:00:00";
							endTimeval  += times[1]+" 23:59:59";
						}else{
							beginTimeval+= timeVal+" 00:00:00";
							endTimeval  += timeVal+" 23:59:59";
						}
					}
					param[name] = timeVal;
				}else{
					beginTimeval = $("#edit-"+ tableId + "-"+startTimeName).val();
					endTimeval = $("#edit-"+ tableId + "-"+endTimeName).val();
				}
				if(beginTimeval){
					if(item.dayTimeQuery){
						beginTimeval += " 00:00:00";
					}
					param[startTimeName] = beginTimeval;
				}
				if(endTimeval){
					if(item.dayTimeQuery){
						endTimeval += " 00:00:00";
					}
					param[endTimeName] = endTimeval;
				}
				continue;
			}
			if(item.vali && item.vali.date){
				var timeVal = $("#edit-"+ tableId + "-"+name).val();
				if(timeVal){
					param[name] = timeVal;
				}
				continue;
			}
    		if(rangeIpt){
    			var riLen = rangeIpt.length;
    			for(var g=0;g<riLen;g++){
    				loadParamJson(param, tableKey, tableId, rangeIpt[g], item, isBulkEdit);
    			}
    		}else{
    			loadParamJson(param, tableKey, tableId, name, item, isBulkEdit);
    		}
    	}
    	if(!isEmptyObject(param)){
    		if(type=="edit"){
    			if(!tableKeyVal){
    				tableKeyVal = $("#"+ tableId+ "-edit").find("#"+ tableId +"-tableKey-"+ tableKey).val();
    			}
    			if(!isBulkEdit){
    				param[tableKey] = tableKeyVal;
    			}
    			param["actionName"] = $.i18n("edit");
    		}else{
    			param["actionName"] = $.i18n("new");
    		}
    		return param;
    	}else{
    		return undefined;
    	}
    }
    
    function loadParamJson(param, tableKey, tableId, name, item, isBulkEdit){
		var inputVal,
			comType = item.comType,
			ratio = parseInt(item.ratio);
		if(item.noSubmit){
			return param;
		}
		if(comType == "radio"){
			inputVal = $("#"+ tableId+"-edit").find("[name="+name+"][type='radio']:checked").val();
		}else if(comType == "checkbox"){
			$("#"+ tableId+"-edit").find("[name="+name+"][type='checkbox']:checked").each(function(j, n){ 
			    arr[j] = $(this).val();
			});
			name += "_cb";
			inputVal = arr.join();
		}else if(comType == "enableDisable"){
			inputVal = isCheckedValue($("#"+ tableId+"-edit").find("[name="+name+"]")[0].checked);
		}else if(comType == "content_dynamic" || comType == "contenteditable_original"){
			inputVal = formatPlaceholderContent($("#edit-"+tableId+"-"+name).html(), comType == "contenteditable_original");
		}else if(comType == "portdiy"){
			var $_span = $("#edit-"+tableId+"-"+name).find("span.badge.devPort");
			var mcparamtemp ="";
			for ( var i = 0; i < $_span.length; i++) {
				if(mcparamtemp!=""){
					mcparamtemp+=",";
				}
				mcparamtemp += $($_span[i]).attr("tempDevUidPortno");
			}
			param[name] = mcparamtemp;
			return param;
		}else if(comType == "tagsinput"){
			inputVal = $("#"+ tableId+"-edit").find("[name="+name+"]").val();
		}else if(item.isIdField){
			inputVal = $("#"+ tableId+"-edit").find("[name="+name+"]").val();
			if(inputVal == ""){
				inputVal = 0;
			}
		}else if(comType == "upload_preview"){
			inputVal = "";
		}else{
			inputVal = $("#"+ tableId+"-edit").find("[name="+name+"]").val();
			if(item.sbmtEncrypt){
				inputVal = getEncryptData(inputVal);
			}
			if(inputVal && typeof inputVal === 'string'){
			   inputVal = inputVal.replace(/\u00A0/g, ' ');
			}
		}
		
		if(name==tableKey){
			tableKeyVal = inputVal;
		}
		
		if(item.comType && (item.comType=="timestamp") && inputVal){
			inputVal = get_unix_time(inputVal);
		}
		
		if(ratio && !isNaN(ratio)){
			inputVal = parseInt(CMX.mul(inputVal,ratio));
		}
		if(item.comType && (item.comType=="uploadNumberFile" || item.comType=="uploadFilePreview")){
			inputVal = $("#edit-"+ tableId +"-"+name+"-hidden").val();
		}
		if(inputVal != undefined){
			if(isBulkEdit){
				if(inputVal !=""){
					param[name] = inputVal+"";
				}
			}else{
				param[name] = inputVal+"";
			}
		}
    	return param;
    }
    
    /**
     * 格式化占位符内容
     * @param {string} content - HTML内容字符串
     * @param {boolean} [useOriginalValue=false] - 是否使用原始值
     * @returns {string} 格式化后的纯文本内容
     */
    function formatPlaceholderContent(content, useOriginalValue = false) {
	    const $container = $("<div>").html(content);
	      
	    // 处理input和span.placeholder元素
	    $container.find(useOriginalValue ? "span.placeholder" : "input").each((_, element) => {
	        const $element = $(element);
	        const value = element.tagName === "INPUT" 
	          ? useOriginalValue 
	            ? $element.attr("original_value") || "" 
	            : $element.val() 
	          : $element.text();
	        $element.replaceWith(value);
	    });
	
	    // 处理div.viewPlaceholder元素
	    if (useOriginalValue) {
	        $container.find("div.viewPlaceholder").each((_, element) => {
	          const $input = $(element).find("input");
	          const value = $input.attr("original_value") || "";
	          console.log(value);
	          $(element).replaceWith(value);
	        });
	    } else {
	        // 普通div元素处理
	        $container.find("div").each((_, element) => {
	          const $element = $(element);
	          const content = $element.html().trim();
	          $element.replaceWith(content ? `${content}\r\n` : '');
	        });
	    }
	
	    // 清理HTML标签并替换空格
	    let result = $container.html()
	        .replaceAll("&nbsp;", " ")
	        .replace(/<(?!br\s*\/?)[^>]+>/gi, '');
	    
	    result = result.replace(/<br\s*\/?>/gi, "\n");
	   // result = result.replace(/[ \t]+/g, " ");
	    return result;
    }  
    
    function get_unix_time(dateStr){
        var date =  parseDate(dateStr); 
        var time_str = date.getTime().toString();
        return time_str.substr(0, 10);
    }
    
    function parseDate(strDate){
    	var newstr = strDate.replace(/-/g,'/'); 
    	var date =  new Date(newstr); 
    	return date;
    }
    
    /**
     * 根据月时间获取该月的最后一天时间
     * date_month_str  2023-10
     */
    function getlastDate(date_month_str){
        var dateStr = date_month_str+"-01 00:00:00";
        var date = parseDate(dateStr); 
        var year = date.getFullYear();
        var month = date.getMonth() + 1;
        if(month > 12){
            month = 1;
            year++;
        }
        if (month < 10) {
            month = '0' + month
        }
        var monthLastDay = new Date(year, month, 0).getDate();
        var lastDate = year + '-' + month + '-' + monthLastDay;
        return lastDate;
    }
    
