    }
    
    function calculateObjectHashMd5(obj) {
        const keys = Object.keys(obj).sort();
        const keyValuePairs = keys.map(key => `${key}:${obj[key]}`);
        const hashString = keyValuePairs.join(',');
        return hex_md5(hashString);
    }
    
