	/**
	 * 根据指定key对JSON数组进行排序
	 * @param {Array} arr - 要排序的JSON数组
	 * @param {String} key - 用于排序的属性名
	 * @param {int} ascending - 是否升序排列，默认1升  ,2降
	 * @returns {Array} 排序后的新数组
	 */
   function sortJsonArray(arr, key, ascending = 1) {
	    // 处理空值或非数组情况
	    if (!Array.isArray(arr) || arr.length <= 1) {
	        return [...arr];
	    }
	    
	    return [...arr].sort((a, b) => {
		        // 处理属性不存在的情况
		        const valA = a[key] === undefined ? '' : a[key];
		        const valB = b[key] === undefined ? '' : b[key];
		        
		        // 数字类型排序
		        if (typeof valA === 'number' && typeof valB === 'number') {
		            return ascending == 1 ? (valA - valB) : (valB - valA);
		        }
		        
		        // 字符串类型排序（不区分大小写）
		        if (typeof valA === 'string' && typeof valB === 'string') {
		            return ascending == 1 
		                ? valA.localeCompare(valB, undefined, { sensitivity: 'base' })
		                : valB.localeCompare(valA, undefined, { sensitivity: 'base' });
		        }
		        
		        // 日期类型排序
		        if (valA instanceof Date && valB instanceof Date) {
		            return ascending == 1 ? (valA - valB) : (valB - valA);
		        }
		        return ascending == 1 
		            ? String(valA).localeCompare(String(valB))
		            : String(valB).localeCompare(String(valA));
		    });
	}
   
