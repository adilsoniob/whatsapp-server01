    //2024-01-01 00:01:00
    function oninputIptOneTime(event, obj){
    	var old_time_str = $(obj).attr("temp_time");
    	if(event.inputType == "deleteContentBackward"){
    		$(obj).attr("temp_time", "").val("");
    	} else if(obj.selectionStart == obj.value.length){
    		$(obj).val(old_time_str);
    	} else if(!/^[0-9]*$/.test(event.data)){
    		var idx_selectionStart = obj.selectionStart;
    		$(obj).val(old_time_str);
    		obj.selectionStart = idx_selectionStart -1;
    		obj.selectionEnd = idx_selectionStart -1;
    	} else{
    		var idx = obj.selectionStart;
    		var val = obj.value;
    		var len = val.length;
    		//获取光标后一位是否需要跳过的字符串
    		var jump_str = [" ","-",":"];
    		while(idx < len && jump_str.indexOf(val.charAt(idx))!=-1){
    			idx ++;
    		}
    		var new_val = changeStr(old_time_str, idx - 1, event.data);
    		if(!datetimeUnderlineDatetime(new_val)){
    			var input_v = parseInt(event.data);
                if(idx == 6 || idx == 9 || idx == 12 || idx == 15 || idx == 18){
    			    new_val = changeStr(new_val, idx, input_v == 0 ? "1" : "0");
    			}
    		}
     
    		if(datetimeUnderlineDatetime(new_val)){
    			$(obj).attr("temp_time", new_val).val(new_val);
    			while(idx < len && jump_str.indexOf(new_val.charAt(idx))!=-1){
    				idx ++;
    			}
    			obj.selectionStart = idx;
    			obj.selectionEnd = idx;
    		}else{
                $(obj).val(old_time_str);
    			obj.selectionStart = idx -1;
    			obj.selectionEnd = idx -1;
    			
    		}
    		
    	}
    }
    
