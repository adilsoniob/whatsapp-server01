    function uploadCerFilesToSvr(tableId, files, name){
		if(files.length){
			var file = files[0];
		 	var fileName = file.name;
			var flag = false;
			if(fileName){
				var begIndex = fileName.lastIndexOf(".");
				if (begIndex >=0) {  
					var tempsuffix = fileName.substring(begIndex,fileName.length); 
					if(tempsuffix == ".pfx"){
					     flag = true;
					}
				}
			}
			var filenamespan = $("#edit-"+tableId+"-fileName");
			if(filenamespan && filenamespan.length>0){
				filenamespan.html(fileName);
			}
			
			if(flag){
				var _this = this;
				var $_form = $("#"+tableId+"-edit-form");
				var sbmt_btn = $_form.find("button[type='submit']");
				var sbmt_btn_text = sbmt_btn.text();
				var progressBar = $("#"+tableId+"-progressBar");
				var progressDiv = $("#"+tableId+"-progressDiv");
				var requestUrl = getLocalStorageModel(tableId, "requestUrl");
				var options = {
					type : 'post',
				    url : window.PATH+ requestUrl + "fileUpload/cerFilesToSvr",
					contentType : "application/x-www-form-urlencoded; charset=utf-8",
		            success:function(res){
		            	var h = $.i18n("uploadedSuccessfully")+"&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"+$.i18n("file.size")+":&nbsp;"+formatFileSize(_this.total);
		            	progressDiv.html(uploadMsg(h, true));
		            	
		            	res = eval("(" + res +")");
					    $("#edit-"+tableId+"-"+name+"-hidden")[0].value = res.data;
					    sbmt_btn.text(sbmt_btn_text);
						sbmt_btn.removeAttr("disabled");
		            },
		            beforeSend: function() {
		            	sbmt_btn.text($.i18n("uploading"));
						sbmt_btn.prop("disabled","disabled");
		            	_this.count = 3;
		            	_this.startTime = (new Date()).getTime();
		                _this.preTime = (new Date()).getTime();
		                _this.preLoad = 0;
		            },
		            uploadProgress: function(event, position, total, percentComplete) {
		            	sbmt_btn.prop("disabled","disabled");
			            var percentVal = percentComplete + '%';
			            progressBar.width(percentVal);   
			            
			            var nowTime = (new Date()).getTime();
			            var nowLoad = event.loaded;
			            var timeDelay = (nowTime - _this.preTime) / 1000;
			            var loadedDelay = nowLoad - _this.preLoad;
			            var speed = parseInt(loadedDelay / timeDelay);
			            var preTime = Math.round((event.total - event.loaded) / speed);
		                _this.count += 1;
		                _this.total = total;
		                if(_this.count > 3)
		                {
		                    _this.count = 0;
		                    var h = setPredict(preTime)+" ------- "+formatFileSize(event.loaded) +"/"+formatFileSize(total)+"&nbsp;( "+formatFileSize(speed)+"/s )";
			            	progressDiv.html(uploadMsg(h, true));
		                }
			            _this.preTime = nowTime;
			            _this.preLoad = nowLoad;
			        },
		        }
				$_form.ajaxSubmit(options);return false;
			}else{
				layer.msg.error($.i18n("upload.file.format.error")); 
			}
		}
   }
   
