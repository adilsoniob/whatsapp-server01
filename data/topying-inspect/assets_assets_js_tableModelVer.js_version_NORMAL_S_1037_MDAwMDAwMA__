    function checkAndSetLocalStorageModel(tableId, keyWord, data){
    	if(window.OLD_VERSION != window.WEBSVNVER){
    		var oddVerItem = getOldVerLocalStorageModel(tableId, keyWord, window.OLD_VERSION);
	    	if(oddVerItem){
				removeOldVerLocalStorageModel(tableId,keyWord, window.OLD_VERSION);
				data = checkNewOldLocalStorageModel(data, oddVerItem);
			}
