			          	if(newResult.votpDevContentStat){
			  	    		initVotpDevStatModel(tableId, newResult.votpDevContentStat);
			  	    	}
		      	    	layer.close(loadInx); 
		      	    	if (typeof callback === 'function') {
			                callback(true);
			            }
	      	    	} catch (error) {
	      	    		console.error(error);
	    	            if (typeof callback === 'function') {
	    	                callback(false);
	    	            }
	    	        } finally {
	    	            layer.close(loadInx);
	    	        }
	      	    }, 
	      	    error: function (xhr, type, exception) {
	      	    	layer.close(loadInx); 
	      	    	if (typeof callback === 'function') {
    	                callback(false);
    	            }
	            }
	      	});
  	    }
    }
    
    function md5Json(json) {
		if (typeof json !== 'object' || json === null) {
		    return json;
		}
		var str = "";
		for (let key in json) {
		    if (json.hasOwnProperty(key)) {
		    	str += key + json[key];
		    }
		}
		return hex_md5(str).toString();
	}
    
