    function getAfterConversionDateTime(time, timezone){
    	 var datetime = new Date();
    	 datetime.setTime(getAfterConversionTimeStamp(time, timezone));
	   	 return datetime;
    }
    
    function getAfterConversionTimeStamp(time, timezone){
    	 if(!time){
	   		 return "";
	   	 }
	   	 var ctz = getLocalStorageModel("clientSysTimeZoneID", "timeZone");
	   	 if(ctz=='' || ctz==undefined){
	   		 ctz = setClientTimeZone(ctz);
	   	 }
	   	 var clientTimeZone  = new Date().getTimezoneOffset();
	   	 var time_v = time * 1000 + (parseInt(clientTimeZone) * 60 * 1000) +  (parseInt(ctz) * 60 * 1000);
	   	 if(timezone){
	   		 time_v =  time_v + ((parseInt(timezone) * 60 * 1000) - (parseInt(ctz) * 60 * 1000));
	   	 }
	   	 return time_v;
    }
    
