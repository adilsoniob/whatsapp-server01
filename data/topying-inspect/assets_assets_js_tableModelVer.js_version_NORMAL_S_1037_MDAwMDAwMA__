    /**
     * 计算百分比，百分比保留小数点后2位，不四舍五入
     */
    function calculatePercentage(num, total) {
    	if(!num || !isNumber(num) || num ==="0" || !total || !isNumber(total) || total === "0"){
    		return 0;
        }
    	
    	if(num >= total){
    		return 100;
    	}
	    var decimal = 2;
    	var percentage = CMX.div(num, total) * 100;
	    var num = percentage.toString();
	    const index = num.indexOf('.');
	    if(index !==-1){
	    	num = num.substring(0, decimal + index + 1);
	    }else{
	    	num = num.substring(0);
	    }
	    return parseFloat(num).toFixed(decimal);
	}
    
    function _getRandomString(len) {
