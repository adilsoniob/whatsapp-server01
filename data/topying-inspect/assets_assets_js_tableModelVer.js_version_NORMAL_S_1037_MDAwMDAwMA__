	function secondToDayHourMinuteSecond(theTime){
	    var theTime1 = 0;// 分
	    var theTime2 = 0;// 小时
	    var theTime3 = 0;// 天
	    if(theTime >= 60) {   
	        theTime1 = parseInt(theTime/60);
	        theTime = theTime%60;
            if(theTime1 >= 60) {
	            theTime2 = parseInt(theTime1/60);
	            theTime1 = theTime1%60;
	            if(theTime2 >= 24){
	            	theTime3 = parseInt(theTime2/24);
	            	theTime2 = theTime2%24;
	            }
            }
	    }
