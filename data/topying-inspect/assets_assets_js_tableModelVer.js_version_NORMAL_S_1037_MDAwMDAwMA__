     function encryptString(str) {
	    let encryptedStr = ''; // 存放加密后的结果
	    for (let i = 0; i < str.length; i++) {
	        const charCode = str[i].charCodeAt(); // 获取当前字符的ASCII值
	        
	        if (isNaN(charCode)) continue; // 如果不是有效的字符则跳过该字符
	        
	        encryptedStr += charCode; // 在每个字符之间添加空格分隔符号
	    }
	    return encryptedStr.trim(); // 去除最后多余的空格并返回加密后的结果
     }
     
