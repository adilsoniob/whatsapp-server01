	function clk_placeholder_cell_mod(tableId, cellStr, event) {
	    // 1. 阻止事件默认行为+冒泡，避免点击时焦点从输入框丢失（关键）
	    if (event) {
	        event.preventDefault();
	        event.stopPropagation();
	    }
	    const targetId = 'edit-' + tableId + '-sms';
	    var msgTemplate = $("#" + targetId);
	    var smsElement = msgTemplate[0]; // 取原生DOM，方便后续操作
	    var insertMsgTemplate = msgTemplate.html();

	    // 空输入框时强制聚焦，确保后续光标操作有效
	    if (insertMsgTemplate.trim() === "") {
	        smsElement.focus();
	    }

	    const selection = window.getSelection();
	    // 无有效选区时，直接追加到末尾并聚焦
	    if (!selection.rangeCount) {
	        msgTemplate.html(msgTemplate.html() + getPlaceholderDom(cellStr).outerHTML);
	        smsElement.focus();
	        keepCursorEnd(smsElement); // 复用你原有光标到末尾的方法
	        return;
	    }

	    const range = selection.getRangeAt(0);
	    const startContainer = range.startContainer;
	    const endContainer = range.endContainer;

	    // 生成要插入的占位符DOM节点（核心修复：字符串→真实DOM）
	    const placeholderElement = getPlaceholderDom(cellStr);
	    // 校验光标是否在目标输入框内
	    function hasTargetId(node, targetId) {
	        while (node) {
	            if (node.id === targetId) {
	                return true;
	            }
	            node = node.parentNode;
	        }
	        return false;
	    }
	    const isInTarget = hasTargetId(startContainer, targetId) && hasTargetId(endContainer, targetId);
	    
	    if (isInTarget) {
	        // 核心：插入真实DOM节点（原代码传字符串导致插入失败）
	        range.insertNode(placeholderElement);
	        // 光标移到插入元素的后方（保持输入习惯）
	        const newRange = document.createRange();
	        newRange.setStartAfter(placeholderElement);
	        newRange.collapse(true); // 折叠为光标，非选中状态
	        selection.removeAllRanges();
	        selection.addRange(newRange);
	        // 强制聚焦输入框，彻底避免光标跑到其他元素
	        smsElement.focus();
	    } else {
	        // 降级处理：光标不在目标框时，追加到末尾并定位光标
	        msgTemplate.html(msgTemplate.html() + placeholderElement.outerHTML);
	        smsElement.focus();
	        keepCursorEnd(smsElement);
	    }
	}

	// 抽离公共方法：生成占位符DOM节点，避免重复代码
	function getPlaceholderDom(cellStr) {
	    return $(`<input disabled='' class='in-var ${window.LANGUAGE}' value='{${cellStr}}'>`)[0];
	}
	
