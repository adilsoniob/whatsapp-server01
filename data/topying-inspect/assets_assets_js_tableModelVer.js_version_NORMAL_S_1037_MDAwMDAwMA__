        }
        toggleRefreshState(tableId, !state.isRefreshing);
    }

    function toggleRefreshState(tableId, startRefresh) {
        const state = tableRefreshState[tableId];
        const $autoRefreshI = $("#"+tableId+"-tools-autoRefresh").find("i");
        clearTimeout(state.timer);
        if (startRefresh) {
            $autoRefreshI.addClass("fa-spin");
            state.isRefreshing = true;
            autoRefreshData(tableId);
        } else {
            $autoRefreshI.removeClass("fa-spin");
            state.isRefreshing = false;
        }
    }

    
    function autoRefreshData(tableId) {
        const state = tableRefreshState[tableId];
        
        if ($("#"+tableId)[0] && state.isRefreshing) { 
            const page = $("#"+tableId+"-footBody").find("ul>li.active>a").attr("page");
            
            queryTableDataModel(tableId, page, (success) => {
                if (success && state.isRefreshing) {
                    state.timer = setTimeout(() => {
                        autoRefreshData(tableId);
                    }, state.interval);
                }
            });
        }
    }
    
    
