			}
		}
		return rowHtml;
	}
	
	function sortComData(comData){
		for(var j=0,len = comData.length; j< len -1 ;j++){
			for(var z=0,clen = comData.length; z< clen - j -1 ;z++){
				if(comData[z][2] > comData[z+1][2]){
					var swap = comData[z];
					comData[z] = comData[z+1];
					comData[z+1] = swap;
				}
			}
		}
		return comData;
	}
	
