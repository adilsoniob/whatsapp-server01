	function dateJSONFtt(fmt, json_date){
		  var o = {   
		    "M+" : json_date.month,                  
		    "d+" : json_date.date,                     
		    "h+" : json_date.hours,                    
		    "m+" : json_date.minutes,                  
		    "s+" : json_date.seconds            
		  };   
		  if(/(y+)/.test(fmt))   
		    fmt=fmt.replace(RegExp.$1, (json_date.year+"").substr(4 - RegExp.$1.length));   
		  for(var k in o)   
		    if(new RegExp("("+ k +")").test(fmt))   
		  fmt = fmt.replace(RegExp.$1, (RegExp.$1.length==1) ? (o[k]) : (("00"+ o[k]).substr((""+ o[k]).length)));   
		  return fmt;   
	}
	
