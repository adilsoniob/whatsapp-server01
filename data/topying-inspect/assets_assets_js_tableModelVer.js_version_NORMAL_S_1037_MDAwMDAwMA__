  	/**
  	 * disabledInput([svrip,svrport,authname,authpwd,minSendtvl,maxSendtvl,frecvuser],[1,1,1,1,1,1,1], value, true);
  	 * arrayId array
  	 * arrayEnables  数组或者二维数组 
  	 * value         选中或者不选中的值
  	 * notEqual    false :  arrayEnables == value,  true : arrayEnables != value 
  	 */
  	function disabledInput(arrayId, arrayEnables, val, notEqual) {
	  	arrayId.forEach((id, index) => {
	  	    const element = $(`#${id}`);
	  	    if (!element.length) return;
	  	    
	  	    const conditions = arrayEnables[index];
	  	    const isEnabled = Array.isArray(conditions) 
	  	      ? conditions.some(cond => notEqual ? val !== cond : val === cond)
	  	      : notEqual ? val !== conditions : val === conditions;
	  	    
	  	    toggleFormElement(element, isEnabled);
	    });
  	}
  	
  	function toggleFormElement($element, isEnabled) {
  	    const $formGroup = $element.closest("div.form-group");
  	    $element.prop("disabled", !isEnabled);
  	    if (isEnabled) {
	  	    $formGroup.show();
  	    } else {
	  	    $formGroup.hide();
  	    }
  	}  
  	
