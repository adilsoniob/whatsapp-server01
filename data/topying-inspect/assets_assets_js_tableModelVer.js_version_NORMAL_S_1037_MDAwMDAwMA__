    function changeDecimalBuZero(number, bitNum){
    	var f_x = parseFloat(number);
    	if (isNaN(f_x) || f_x == 0){
    		return 0;
    	}
    	var s_x = number.toString();
    	var pos_decimal = s_x.indexOf('.');
    	if (pos_decimal < 0){
    		s_x += '.';
    		for(var i=0;i<bitNum;i++){
    		    s_x += '0';
    		}
    	}else{
    		while(s_x.split(".")[1].length < bitNum) {
        		s_x += '0';
        	}
    	}
    	return s_x;
    }
    
