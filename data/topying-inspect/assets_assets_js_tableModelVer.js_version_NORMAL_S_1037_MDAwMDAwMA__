   function queryDataByConditions(queryData, query_json) {
	    for (let i = 0; i < queryData.length; i++) {
	        const dataRow = queryData[i];
	        let isMatch = true;

	        for (const key in query_json) {
	            if (query_json.hasOwnProperty(key)) {
	                if (dataRow[key] == null || dataRow[key] != query_json[key]) {
	                    isMatch = false;
	                    break;
	                }
	            }
	        }
	        if (isMatch) {
	            return dataRow;
	        }
	    }
	    return null;
	}
   
