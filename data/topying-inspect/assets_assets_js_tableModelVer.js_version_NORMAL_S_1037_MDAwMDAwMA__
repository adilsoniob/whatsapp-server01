    function initSearchFun(tableId, i18nPrefix, queryList, queryListOldVal){
    	var queryLen = queryList.length;
    	var search_prefix = "search-"+ tableId + "-";
    	for(var i=0;i<queryLen;i++){
			var queryItem = queryList[i],
				name = queryItem.name,
				advQry = queryItem.advQry,
				comType = queryItem.comType;
			var v = queryListOldVal[i];
			var id_str = "#"+ search_prefix + name;
			if(v){
				$(id_str).val(v);
			}
			if(advQry && (comType== "select" || comType== "enableDisable")){
				var $SearchName = $(id_str);
				$SearchName.select2({
					minimumResultsForSearch: 8
				});
				var comData = queryItem.comData;
				var cd = comData;
				if(comData && typeof comData=='string'){
					comData = g_var.view[comData];
		    	}
				var arr_comData = comData?comData:$.i18n(i18nPrefix + name+ ".comData");
				arr_comData = btypeComDataDef(arr_comData, cd, name);
				var def_val = $SearchName.find('option:first').val();
				var def_text = $SearchName.find('option:first').text();
				dynamicLoadingSelect2Data($SearchName, arr_comData, [def_val, def_text]);
			}else if(comType== "multiple"){
				$(id_str).select2({
					placeholder: $.i18n(i18nPrefix + name+ ".help"),
					allowClear: true
				});
			}else if(comType== "MAC"){
				mac_mask($(id_str));
			}
			
            if(queryItem.timeLimit){
				$.datepickerjQ(tableId);
				var s_bt_id = search_prefix + queryItem.timeLimit[0];
				var s_et_id = search_prefix + queryItem.timeLimit[1];
				if(queryItem.dayTimeQuery){
					if(queryItem.maxTimeOffsetDay){
						initLaydateDayCom(tableId, queryItem.vali, queryItem.timeLimit, s_bt_id, s_et_id, 0, new Date(new Date().getTime() + queryItem.maxTimeOffsetDay * 24 * 60 * 60 * 1000));
					}else{
						initLaydateDayCom(tableId, queryItem.vali, queryItem.timeLimit, s_bt_id, s_et_id);
					}
					if(!(queryItem.vali && queryItem.vali.defStartTime===false)){
						datePickersDay(tableId, "#"+ s_bt_id, "#"+ s_et_id);
					}
				}else{
					var initstartTime,initendTime;
					if(v &&  v[0] && v[1]){
						initstartTime = v[0];
						initendTime = v[1]
					}else if(queryItem.initTimeData){
						if(queryItem.initTimeData.initstart && (queryItem.initTimeData.initstart.offsetDay || queryItem.initTimeData.initstart.offsetDay == 0) ){
							var dateFormat = "yyyy-MM-dd hh:mm:ss";
							if(queryItem.initTimeData.initstart.dateFormat){
								dateFormat = queryItem.initTimeData.initstart.dateFormat;
							}
							var d = new Date(new Date().getTime() + queryItem.initTimeData.initstart.offsetDay * 24 * 60 * 60 * 1000)
							initstartTime = dateZoneToString(d, dateFormat);
						}
						if(queryItem.initTimeData.initend){
							initendTime = queryItem.initTimeData.initend;
						}
					}
					initLaydate2(tableId, queryItem, initstartTime, initendTime);
					if(!(queryItem.vali && queryItem.vali.defStartTime===false)){
					    datePickers(tableId, "#"+ s_bt_id, "#"+ s_et_id, initstartTime, initendTime);
					}
				}
				if(!window.IS_MOBILE && queryItem.iptTime){
					$(id_str).attr("temp_time",$(id_str).val());
				}
			}else if(queryItem.vali && queryItem.vali.date){
				laydate.render({
				    elem: id_str ,istime: true,max: dateFtt(queryItem.vali.dateFormat,new Date()),type: 'datetime'
				});
			}
            addEventListenerFun(tableId, "search", queryItem);
		}
    }
    
    function addEventListenerFun(tableId, type, item){
    	if(item.addEventListener){
    		var arr = item.addEventListener;
    		var eventListener_triggerEventType = arr[2];
    		if(eventListener_triggerEventType == "all" || eventListener_triggerEventType == type || (eventListener_triggerEventType == 'edit' && type == 'new')){
	    		var comType = item.comType;
	    		var name = item.name;
				var eventListener_funName = arr[1];
				var eventListener_triggerEvent = arr[0];
				var ipt_id_prefix = type == "search" ? "search" : "edit";
				var event_jq = $("#"+ipt_id_prefix+"-"+ tableId +"-"+ name);
				if(comType== "select" || comType== "multiple"){
					event_jq.on(eventListener_triggerEvent ,function(event) {
						window[eventListener_funName].apply(this, [tableId, this.options[this.selectedIndex].value, this.id]);
					});
				}else if(comType== "radio"){
					event_jq = $('input[type="radio"][name="'+name+'"]');
					event_jq.on(eventListener_triggerEvent ,function(event) {
						window[eventListener_funName].apply(this, [tableId, $("input[type='radio'][name='"+name+"']:checked").val()]);
					});
				}else if(comType== "enableDisable"){
					event_jq.on(eventListener_triggerEvent ,function(event) {
						window[eventListener_funName].apply(this, [tableId, this.checked]);
					});
				}else{
					event_jq.on(eventListener_triggerEvent ,function(event) {
						window[eventListener_funName].apply(this, [tableId, this.value, this.id, type]);
					});
				}
				event_jq.trigger(eventListener_triggerEvent);
    		}
		}
    }
    
    function initTopSearchWidgetModel(tableId){
		var paramsStorage = getLocalStorageModel(tableId, "tableParams"),
			params = paramsStorage.trs,
			i18nPrefix = paramsStorage.i18nPrefix,
			paramsLen = params.length,
			queryList = [];
		    queryListOldVal = [];
		for(var i=0; i<paramsLen; i++){
			if(params[i].advQry && (window.search_mode == "top" && (params[i].topSearch || params[i].topSearchSet)) || (window.search_mode == "thead" && params[i].theadSearchDef)){
				queryList.push(params[i]);
				if(params[i].timeLimit){
					var tl = params[i].timeLimit;
					var lg = tl.length;
					var queryArray = [];
					for(var x=0; x<lg; x++){
						var s_val = $("#search-"+tableId+"-"+tl[x]).val();
						if(s_val){
							queryArray.push(s_val);
						}
					}
					if(queryArray && queryArray.length > 0){
						queryListOldVal.push(queryArray);
					}else{
						queryListOldVal.push(0);
					}
				}else{
					queryListOldVal.push($("#search-"+tableId+"-"+params[i].name).val());
				}
			}
		}
		
		if(window.search_mode != "thead" || (window.search_mode == "thead" && queryList.length > 0)){
		    var html = '<div class="panel-body"><div id="'+tableId+'_top_search_mode" style="width:calc(100% - 237px);float:left;min-height: 38.5px;">';
		    if(window.IS_MOBILE){
		    	html = '<div class="panel-body"><div style="width:100%;float:left;">';
		    }
		    html += loadSearchModel(tableId, i18nPrefix, queryList, queryListOldVal);
			if(!window.IS_MOBILE){
				html += '</div><div style="width:237px;float:right;">';
				html += '<div class="col-md-12 text-right">';
				if(window.search_mode == "top"){
					html += getSearchFilter(tableId);
				}
			}
			if(!(window.IS_MOBILE && window.search_mode == "thead")){
				var queryTableDataFun = "queryTableDataModel";
				if(searchBeforeConditionCheckTabId.indexOf(tableId) >=0){
					queryTableDataFun = "searchBeforeConditionCheck";
				}
				html += '<button class="btn btn-success" style="height:30px;margin-right:5px;" onClick="'+queryTableDataFun+'(\''+tableId +'\')"><i class="fa fa-search"></i>'+ $.i18n("search")+'</button>'
			}
			//	+'<button class="btn btn-darkorange" style="height:30px;" onClick="resetSearchCondition(\''+tableId +'\')"><i class="fa fa-undo"></i>'+ $.i18n("page.clear_search")+'</button>'
				+'</div></div></div>';
			$("#" +tableId +"-searchArea").html(html);
			initSearchFun(tableId, i18nPrefix, queryList, queryListOldVal);
			
		}
	}
    
    /**
     * 正则表达式验证是否是 1-9数字
     */
    function isSingleDigitNumber(str) {
        return /^[1-9]$/.test(str);
    }
    
    //24-01-01 00:01:00 - 24-01-01 00:02:00
    function oninput_iptTime(event, obj, tableId, start_name, end_name){
    	var old_time_str = $(obj).attr("temp_time");
    	if(event.inputType == "deleteContentBackward" || obj.selectionStart == obj.value.length){
    		$(obj).val(old_time_str);
    	} else if(!/^[0-9]*$/.test(event.data)){
    		var idx_selectionStart = obj.selectionStart;
    		$(obj).val(old_time_str);
    		obj.selectionStart = idx_selectionStart -1;
    		obj.selectionEnd = idx_selectionStart -1;
    	} else{
    		var idx = obj.selectionStart;
    		var val = obj.value;
    		var len = val.length;
    		//获取光标后一位是否需要跳过的字符串
    		var jump_str = [" ","-",":"];
    		while(idx < len && jump_str.indexOf(val.charAt(idx))!=-1){
    			idx ++;
    		}
    		
    		var new_val = changeStr(old_time_str, idx - 1, event.data);
    		if(!datetimeUnderlineDatetimeReg(new_val)){
    			var input_v = parseInt(event.data);
                if(idx == 4 || idx == 7 || idx == 10 || idx == 13 || idx == 16 || idx == 24 || idx == 27 || idx == 30 || idx == 33 || idx == 36){
    			    new_val = changeStr(new_val, idx, input_v == 0 ? "1" : "0");
    			}
    		}
    		if(datetimeUnderlineDatetimeReg(new_val)){
