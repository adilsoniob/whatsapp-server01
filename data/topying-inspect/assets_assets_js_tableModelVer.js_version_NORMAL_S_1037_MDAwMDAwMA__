	function getDateArray(date){
		var darray={}; 
		darray.year=date.year; 
		darray.month=date.month - 1; 
		var day=date.date; 
		if(date.hours == 23 && date.minutes == 59 && date.seconds == 59){ 
			day = day + 1; 
		}else{ 
			darray.hours = date.hours; 
			darray.minutes = date.minutes; 
			darray.seconds = date.seconds; 
		} 
		darray.date=day; 
		return darray;  
	}
		 
