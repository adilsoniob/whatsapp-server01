    * @param formId
    */
   function reValidateField(fieldname, formId) {
       //校验之前重置某个验证字段验证规则
       $("#"+formId).data("bootstrapValidator").updateStatus(fieldname,  "NOT_VALIDATED",  null );
       //单独校验这个field
       $("#"+formId).data('bootstrapValidator').validateField(fieldname);
   }
   
