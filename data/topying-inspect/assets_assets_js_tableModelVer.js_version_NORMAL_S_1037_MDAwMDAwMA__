    /**
     * 校验Blob内容是否为有效Excel，避免302自动跳转后下载登录页HTML
     * @param {Blob} blob 响应的Blob对象
     * @param {String} fileName 下载文件名
     */
    function validateBlobAndDownload(blob, fileName) {
        // 1. 先判断Blob的MIME类型（初步过滤）
        const validExcelMime = [
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", // xlsx
            "application/vnd.ms-excel" // xls
        ];
        // 2. 若MIME类型不是Excel，解析Blob内容判断是否为登录页
        if (!validExcelMime.includes(blob.type)) {
            const reader = new FileReader();
            reader.onload = function (e) {
                const content = e.target.result;
                // 判断内容是否包含登录页特征（如登录表单、login关键词）
                if (content.includes("<!DOCTYPE html>")) {
                    window.location.href = window.PATH + "/login";
                }
            };
        }

        // 3. 有效Excel文件：执行下载
        var aElem = document.createElement('a');
        aElem.href = window.URL.createObjectURL(blob);
        aElem.download = "Template_" + fileName;
        // 释放URL对象（避免内存泄漏）
        aElem.onclick = function () {
            setTimeout(() => {
                window.URL.revokeObjectURL(aElem.href);
            }, 100);
        };
        document.body.appendChild(aElem);
        aElem.click();
        document.body.removeChild(aElem);
    }
	
