	/**    WS  webSocket       **/
	let ws;
	let heartbeatInterval;
	let pongTimeout;
	let reconnectTimer;
	let reconnectAttempts = 0;
	const MAX_RECONNECT_ATTEMPTS = 3; // 最大重连次数
	const INITIAL_RECONNECT_DELAY = 3000; // 初始重连延迟(ms)
	const MAX_RECONNECT_DELAY = 30000; // 最大重连延迟(ms)
	const BASE_HEARTBEAT_INTERVAL = 60000; // 基础心跳间隔（60秒）
	const PONG_TIMEOUT = 10000; // 等待Pong超时时间(ms)
	const HEARTBEAT_JITTER = 10000; // 随机偏移范围(±20%)
	function connectWebSocket() {
		if (window.IS_CONNECTED_WEBSOCKET) {
	        console.log("Already connected, skip new connection");
	        return;
	    }
		
		cleanupConnection();
	    
	    // 创建新的WebSocket连接
	    ws = new WebSocket(window.WSHOST + '/websocket?md_token=' + window.WS_TOKEN);
	    ws.onopen = function() {
	        console.log('WebSocket connection established');
	        reconnectAttempts = 0;
	        window.IS_CONNECTED_WEBSOCKET = true;
	        setTimeout(() => {
	             startHeartbeat();
	        }, BASE_HEARTBEAT_INTERVAL);
	    };

	    ws.onmessage = function(event) {
	        // 处理接收到的消息
	        eventSourceOnmessage(event.data);
	        
	        // 如果是心跳响应消息
	        if (event.data === 'pong') {
	            resetPongTimeout();
	        }
	    };

	    ws.onclose = function(event) {
	    	window.IS_CONNECTED_WEBSOCKET = false;
	    	console.log(`WebSocket connection closed. Code: ${event.code}, Reason: ${event.reason}`);
	        stopHeartbeat();
	        
	        if (event.code === 4009) {
	        	cleanupConnection();
	            console.log('Duplicate connection, stop reconnection');
	            return;
	        }
	        
	        if (event.code === 1000 || event.code === 1009 || event.code === 1008 || event.code === 1011 ||  event.code === 4008 || event.reason.includes('Invalid User Session')) {
	            cleanupConnection();
	            console.log('Session invalid, stopping reconnection attempts');
	            return;
	        }
	        
	        handleReconnect();
	    };

	    ws.onerror = function(error) {
	    	window.IS_CONNECTED_WEBSOCKET = false;
	        console.error('WebSocket error occurred: ', error);
	        ws.close(); // 发生错误时关闭连接，触发重连
	    };
	}
	
	function getRandomizedHeartbeatInterval() {
	    const jitter = Math.floor(Math.random() * (HEARTBEAT_JITTER * 2 + 1)) - HEARTBEAT_JITTER;
	    return BASE_HEARTBEAT_INTERVAL + jitter;
	}

	// 处理重连逻辑
	let reconnectCoolDown = false;
	function handleReconnect() {
	    if (window.IS_CONNECTED_WEBSOCKET || reconnectCoolDown) {
	        return;
	    }
	    reconnectAttempts++;
	    if (reconnectAttempts > MAX_RECONNECT_ATTEMPTS) {
	        console.log("Max reconnect attempts reached");
	        window.IS_CONNECTED_WEBSOCKET = false;
	        return;
	    }
	    reconnectCoolDown = true;
	    const delay = Math.min(INITIAL_RECONNECT_DELAY * Math.pow(2, reconnectAttempts - 1), MAX_RECONNECT_DELAY);
	    const jitter = Math.random() * 2000;
	    reconnectTimer = setTimeout(() => {
	        reconnectCoolDown = false;
	        connectWebSocket();
	    }, delay + jitter);
	}
    
	function startHeartbeat() {
	    // 首次发送心跳
	    sendHeartbeat();
	    
	    // 递归调度下一次心跳（每次都计算随机间隔）
	    const scheduleNextHeartbeat = () => {
	        // 获取带随机偏移的间隔（如24-36秒之间）
	        const randomInterval = getRandomizedHeartbeatInterval();
	        // 用setTimeout替代setInterval，确保每次间隔都重新计算
	        heartbeatInterval = setTimeout(() => {
	            sendHeartbeat();
	            scheduleNextHeartbeat();
	        }, randomInterval);
	    };
	    
	    scheduleNextHeartbeat();
	}

	// 停止心跳机制
	function stopHeartbeat() {
	    clearInterval(heartbeatInterval);
	    clearTimeout(pongTimeout);
	}
	
	function cleanupConnection() {
	    clearTimeout(reconnectTimer);
	    stopHeartbeat();
	    if (ws) {
	        ws.onopen = null;
	        ws.onmessage = null;
	        ws.onclose = null;
	        ws.onerror = null;
	        ws = null;
	    }
	}
	

	// 发送心跳消息
	function sendHeartbeat() {
	    if (ws && ws.readyState === WebSocket.OPEN) {
	        ws.send('ping');
	        
	        // 设置超时定时器
	        pongTimeout = setTimeout(() => {
	            ws.close(1006, 'Pong timeout'); // 非正常关闭，触发重连
	        }, PONG_TIMEOUT);
	    }
	}

	// 重置超时定时器
	function resetPongTimeout() {
	    clearTimeout(pongTimeout);
	}
	
