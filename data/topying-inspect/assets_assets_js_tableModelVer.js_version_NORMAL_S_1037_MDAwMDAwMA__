	function sumJson(objA, objB) {
		const result = Object.assign({}, objA); 
	    Object.keys(objB).forEach(key => {
		    if (result.hasOwnProperty(key)) {
		        result[key] = result[key] + objB[key];
		    } else {
		        result[key] = objB[key];
		    }
	    });
	
	    return result;
	}
	
