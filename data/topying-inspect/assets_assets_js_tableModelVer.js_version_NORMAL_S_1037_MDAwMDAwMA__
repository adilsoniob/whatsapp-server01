    function queryTableDataModelStat(tableId){
       var url = getLocalStorageModel(tableId, "requestUrl");
  	   var queryUrl = url + "list.ajax",
  	       queryParams = getSearchParams(tableId);
  	   var homePageStatStartTimeStr = getLocalStorageModel("homePageStatStartTimeStr", "");
  	   if(homePageStatStartTimeStr){
  		   homePageStatStartTimeStr = encodeURIComponent(homePageStatStartTimeStr);
  		   queryParams["cx_GTE-|-stattm"] = homePageStatStartTimeStr;
  	   }
  	   var loadInx = layer.load(2);
       $.ajax({
      	    url:window.PATH + queryUrl,
      	    data: queryParams,
      	    type:"post",
      	    dataType: "json",
      	    success:function(req){
      	    	var newResult = req.data, 
      	    		data = newResult.contentList;
      	    	setLocalStorageModel(tableId, "queryData", data);
      	    	showDataModel(tableId);//Create table
      	    	layer.close(loadInx);
      	    }, 
      	    error: function (xhr, type, exception) {
      	    	layer.close(loadInx);
          }
      	}); 
     }
    
