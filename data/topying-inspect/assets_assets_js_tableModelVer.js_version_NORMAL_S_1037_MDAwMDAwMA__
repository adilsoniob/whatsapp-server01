    /**
     * 
     * A,B,C,D,E,F,G,H,I,J,K
     * 屏蔽B-D  G-J
     * [[B,D],[G,J]]
     * 中间的 E,F 跳过
     * [[开始屏蔽的字段， 结束屏蔽的字段],[开始屏蔽的字段， 结束屏蔽的字段].....]
     * 删除需要屏蔽的字段，删除的开始字段和接收的字段
     */
    function reomveTableItemStartEnd(tableItem_data, start_end_remove_field_arr){
    	var start_remove_field_arr = [];
    	var end_remove_field_arr = [];
    	for(var j=0;j<start_end_remove_field_arr.length;j++){
    		start_remove_field_arr.push(start_end_remove_field_arr[j][0]);
    		end_remove_field_arr.push(start_end_remove_field_arr[j][1]);
    	}
        var arr = tableItem_data.trs;
        var new_item = [];
        var len = arr.length;
        var f = false;
	    for(var i=0;i<len;i++){
	        var name = arr[i].name;
	        if(start_remove_field_arr.indexOf(name) >=0){
	        	f = true;
	        }
	        if(end_remove_field_arr.indexOf(name) >=0){
	        	f = false;
	        	continue;
	        }
	        if(f){
	        	continue;
	        }
	        new_item.push(arr[i]);
	    }
	    tableItem_data.trs = new_item;
	    return tableItem_data;
	}
    
