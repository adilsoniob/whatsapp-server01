    /**
     * 升级版本后， 保留之前设置的显示隐藏字段（show）, 隐藏显示搜索框（topSearchSet）
     * 还需要保留客户设置的列排序问题，需要考虑新版本字段会删除添加.
     */
    function checkNewOldLocalStorageModel(newItem, oddItem){
    	var newItems = newItem.trs;
    	var newItemsLen = newItems.length;
    	var oddItems = oddItem.trs;
        var oddItemsLen = oddItems.length;
        for(var l=0; l<newItemsLen; l++){
        	for(var m=0; m<oddItemsLen; m++){
        		var itemName = newItems[l].name;
        		if(oddItems[m].name == itemName){
        			if(oddItems[m].show != newItems[l].show){
        				newItems[l].show = oddItems[m].show;
        			}
        			if(oddItems[m].topSearchSet != newItems[l].topSearchSet){
        				newItems[l].topSearchSet = oddItems[m].topSearchSet;
        			}
        			continue;
        		}
        	}
        }
        newItem.trs = newItems;
        return newItem;
    }
    
