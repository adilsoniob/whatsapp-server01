	                        onclick='clk_placeholder_cell_mod("${tableId}","${colName}", event)'>${colName}</li>`;
	                    
	                    //smsCellPlaceholderHtml += `<li class='in-item insertPlaceholder' 
	                    //    data="${colName}">${colName}</li>`;
	                }
	            }
	            tableHtml += "</tr></thead><tbody>";
	        }
	        tableHtml += "<tr>";
	        if (!showFieldSelection) {
	            tableHtml += `<td>${$.i18n("row") + (i + 1)}</td>`; // 行号
	        }
	        for (let x = 0; x < cellCnt; x++) {
	            tableHtml += `<td>${x < cellLen ? cellData[x] : ''}</td>`;
	        }
	        tableHtml += "</tr>";
	    }
	    tableHtml += "</tbody></table>";
	    if (showFieldSelection && initColCnt === cellCnt) {
	        $("#"+tableId+"-fileTab tbody").html(tableHtml.match(/<tbody>([\s\S]*)<\/tbody>/)[1]);
	    } else {
