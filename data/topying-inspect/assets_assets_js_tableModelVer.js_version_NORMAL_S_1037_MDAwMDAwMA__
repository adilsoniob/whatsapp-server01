   function specifyRateToSystemRate(tableId){
	   var f = false;
	   var userid = $('#edit-'+tableId+'-userid').val();
	   if(!userid){
		   return; 
	   }
	   var comData = eval("g_var.view.userIdSpecifyCurrencySelectVals");
	   if(comData){
		   var select_user_specifyCurrency = "";
		   for(var k=0,len=comData?comData.length:0; k<len; k++){
		       if(comData[k][0] == userid){
		    	  select_user_specifyCurrency = comData[k][2];
		    	  break;
		       } 
		   }
		   if(select_user_specifyCurrency == "" || !select_user_specifyCurrency){
			   select_user_specifyCurrency = window.TO_CURRENCY;
		   }
		   f = window.TO_CURRENCY != select_user_specifyCurrency;
	   }
	   if(!f){
		  return; 
	   }
	   var specifyROE = $('#edit-'+tableId+'-specifyROE').val();
	   var specifyRate = $('#edit-'+tableId+'-specifyRate').val();
	   if(specifyROE != "" && /^(-?[0-9]+(\.[0-9]{1,6})?)$/.test(specifyROE) && specifyRate != "" && /^(-?[0-9]+(\.[0-9]{1,6})?)$/.test(specifyRate)){
			var v = CMX.mul(specifyRate, specifyROE);
			v = floatObj.toFixed(v, 6);
			$('#edit-'+tableId+'-rate').val(v);
	   }
   }
   
