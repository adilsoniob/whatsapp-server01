 	/**
 	 * 金额每隔3位一个逗号，方便读取
 	 * 10000 ---> 10,000
 	 * 1000.1254 ---> 1,000.1254
 	 * 
 	 * @param num 字符串
 	 * @returns
 	 */
 	function toThousands(num){
 		if(num == ""){
 			return "0";
 		}
 		let firstChar = "";
 		num = num + "";
 		if (!isFirstCharDigit(num)) {
 			firstChar = num.charAt(0); 
 			num = num.slice(1);
 		}
	    let result = '', counter = 0;
	    let dot = String(num).indexOf(".");
	    if (dot != -1) {
	        // 获取小数点后面的数字(indexOf和substring都不支持数字，所以要先转字符串才可以用)
	        let dotCnt = String(num).substring(dot + 1, num.length);
	
	        num = String(num).split('.')[0]
	        num = (num || 0).toString();
	        for (var i = num.length - 1; i >= 0; i--) {
	          counter++;
	          result = num.charAt(i) + result;
	          if (!(counter % 3) && i != 0) {
	            result = ',' + result;
	          }
	        }
	        result = result + '.' + dotCnt;
	        return firstChar + result;
	    } else {
	        // alert("没有小数点");
	        return firstChar + (num || 0).toString().replace(/(\d)(?=(?:\d{3})+$)/g, '$1,');
	    }
 	}
 	
 	function isFirstCharDigit(str) {
	    return /^[\d]/.test(str);
	}
 	
