  	function timeZoneMinuteToStr(timeZoneVal){   
	    if(timeZoneVal == "0"){
	    	return "UTC";
	    }
  		if(timeZoneVal){
  			timeZoneVal+="";
	       var text_timeZone = "+";
	       if(timeZoneVal.startsWith("-")){
	    	   text_timeZone = "-";
	    	   timeZoneVal = timeZoneVal.substring(1,timeZoneVal.length);
	       }
	       timeZoneVal = parseInt(timeZoneVal);
	       var hour = Math.floor(timeZoneVal/60);
	       var min = 0;
	       if(timeZoneVal%60>0){
	    	   min = timeZoneVal%60;
	       }
	       return "UTC" + text_timeZone + completionStr(hour) + ":" + (min == 0 ? "00" : completionStr(min));
	    }
	    return ""; 
	}
  	
  	function timeZoneStrToMinute(tzs){       //UTC-11:00
	     var temp=0;
	     if(tzs.length>3){
	        var time_tz = tzs.substring(3);
	        var t = time_tz.split(':');
	        if(parseInt(t[0],10)<0){
	           temp = parseInt(t[0],10)*60 - parseInt(t[1],10);
	        }else{
	           temp = parseInt(t[0],10)*60 + parseInt(t[1],10);
	        }
	     }
	     return temp; 
	}
    
