    function btypeComDataDef(arr_comData, comData_str, name){
    	if(((name == "btype" && comData_str == "btypeVals") || (name == "btypeId" && comData_str == "btypeIdIds"))){
			for(var q=0,q_len=arr_comData?arr_comData.length:0; q<q_len; q++){
		    	if(arr_comData[q][0]== 0 && arr_comData[q][1] == "AllType"){
		    		arr_comData[q][1] = $.i18n("business_type."+arr_comData[q][1]);
				}
			}
		}
    	return arr_comData;
    }
    
    function btypeDataDef(comData_arr_idx, comData_arr, comData_str, name){
