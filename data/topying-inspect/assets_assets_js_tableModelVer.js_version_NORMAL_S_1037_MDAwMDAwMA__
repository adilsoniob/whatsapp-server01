    function InitTableMoudle(tableId, toolsAreaId, requestUrl, params, permissions, page,isImport,isExport,isExportTemp,isAddSearchContent,isCollapse,isInitCollapse){
		params = initTableItems(tableId, params);
		initLocalStorage(tableId, requestUrl, params, permissions,isCollapse);
