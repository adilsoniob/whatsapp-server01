   /**
    * 生成的表单增加事件初始化
    * tableId
    * type
    * tableItems
    */
   function initEditEvent(tableId, type, tableItems){
	   var ipt_id_prefix = type == "search" ? "search" : "edit";
	   var id_prefix = ipt_id_prefix+"-"+ tableId +"-";
	   var itemsLen = tableItems.length;
	   for(var i=0;i<itemsLen;i++){
			var queryItem = tableItems[i],
			    i18nPrefix =queryItem.i18nPrefix,
				name = queryItem.name,
				rangeIpt = queryItem.rangeIpt,
				hideEdit = queryItem.hideEdit,
				comType = queryItem.comType;
			if(comType== "select"){
				if(rangeIpt){
					var rangeIptLen = rangeIpt.length;
					for(var g=0;g<rangeIptLen;g++){
						if((type == "search" && queryItem.advQry) || type != "search"){
							$("#"+id_prefix + rangeIpt[g]).select2({
								minimumResultsForSearch: 8
							});
						}
					}
				}else{
					if((type == "search" && queryItem.advQry) || type != "search"){
						$("#"+id_prefix + name).select2({
							minimumResultsForSearch: 8
						});
					}
				}
			}else if(comType== "multiple"){
				var help_tip = $.i18n(i18nPrefix + name+ ".help");
				if(window.search_mode == "thead" && type == "search"){
					help_tip = '';
				}
				
				var select2_json = {
						placeholder: help_tip,
						allowClear: true
					};
				if(queryItem.maximumSelectionLength){
					select2_json.maximumSelectionLength = queryItem.maximumSelectionLength;
				}
				$("#"+id_prefix + name).select2(select2_json);
			}else if(comType== "upload_preview"){
				dropzone_uploaded_add_hover();
			}
			
			if(comType== "MAC"){
				mac_mask($("#"+id_prefix + name));
			}else if(comType=="tagsinput"){
				$("#"+id_prefix + name).tagsinput({
			        allowDuplicates: true,
			        maxChars: 32,
			        maxTags: 50,
			        trimValue: true
			    });
			}else if(comType=="timestamp"){
				var laydate_render_json = {
					elem: "#"+id_prefix + name, istime: true, min: nowTimeConversionTimezone(),type: 'datetime'
				};
				if(queryItem.vali.required){
					var _name = name;
					laydate_render_json.btns = ['now', 'confirm'];
					laydate_render_json.done = function(value, date, endDate){
						$("#"+id_prefix + _name).val(dateJSONFtt("yyyy-MM-dd hh:mm:ss", date));
			            reValidateField(_name, tableId +"-edit-form");
				    }
				}
				laydate.render(laydate_render_json);
			}
			
			if(type == "search" && queryItem.timeLimit){
				$.datepickerjQ(tableId);
				var s_bt_id = id_prefix + queryItem.timeLimit[0];
				var s_et_id = id_prefix + queryItem.timeLimit[1];
				if(queryItem.dayTimeQuery){
					if(queryItem.maxTimeOffsetDay){
						initLaydateDayCom(tableId, queryItem.vali, queryItem.timeLimit, s_bt_id, s_et_id, 0, new Date(new Date().getTime() + queryItem.maxTimeOffsetDay * 24 * 60 * 60 * 1000));
					}else{
						initLaydateDayCom(tableId, queryItem.vali, queryItem.timeLimit, s_bt_id, s_et_id);
					}
					if(!(queryItem.vali && queryItem.vali.defStartTime===false)){
						datePickersDay(tableId, "#"+ s_bt_id, "#"+ s_et_id);
					}
				}else{
					var initstartTime,initendTime;
					if(queryItem.initTimeData){
						if(queryItem.initTimeData.initstart && (queryItem.initTimeData.initstart.offsetDay || queryItem.initTimeData.initstart.offsetDay == 0) ){
							var dateFormat = "yyyy-MM-dd hh:mm:ss";
							if(queryItem.initTimeData.initstart.dateFormat){
								dateFormat = queryItem.initTimeData.initstart.dateFormat;
							}
							var d = new Date(new Date().getTime() + queryItem.initTimeData.initstart.offsetDay * 24 * 60 * 60 * 1000)
							initstartTime = dateZoneToString(d, dateFormat);
						}
						if(queryItem.initTimeData.initend){
							initendTime = queryItem.initTimeData.initend;
						}
					}
					initLaydate2(tableId, queryItem, initstartTime, initendTime);
					if(!(queryItem.vali && queryItem.vali.defStartTime===false)){
					    datePickers(tableId, "#"+ s_bt_id, "#"+ s_et_id, initstartTime, initendTime);
					}
				}
				if(!window.IS_MOBILE && queryItem.iptTime){
					$("#"+ id_prefix + name).attr("temp_time",$("#"+ id_prefix + name).val());
				}
			}else if(queryItem.vali && queryItem.vali.date){
				var dur_time = timeStampToString(new Date().getTime()/1000);
				laydate.render({
				    elem: '#'+id_prefix + name ,
				    istime: true,
				    min: dur_time,
				    type: 'datetime'
				});
			}
			addEventListenerFun(tableId, type, queryItem);
		}
   }
   
   /**
