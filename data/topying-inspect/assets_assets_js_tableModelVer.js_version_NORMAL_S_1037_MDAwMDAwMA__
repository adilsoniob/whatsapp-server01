					   var field = {};
					   field.message = "default error message.";
					   field.validators = validator;
					   fields[name] = field;
				   }
			   }
		   }else{
			   var validator = getValiObj(vali, name);
			   if(validator && !isEmptyObject(validator)){
				   var field = {};
				   field.message = "default error message.";
				   field.validators = validator;
				   fields[name] = field;
			   }
		   }
		   
	   }
	   return fields;
   }
   
   function getValiObj(vali, name){
	   var validatorErrorPrefix = "validator.";
	   var validator = {};
	   if(!(vali && vali.required===false)){
		   validator.notEmpty = {};
		   validator.notEmpty.message = $.i18n(validatorErrorPrefix + "notEmpty");
	   }
	   if(vali){
		   if(vali.emailAddress){
			   validator.emailAddress = {};
			   validator.emailAddress.message = $.i18n(validatorErrorPrefix + "emailAddress");
		   }
		   if(vali.uri){
			   validator.uri = {};
			   validator.uri.message = $.i18n(validatorErrorPrefix + "uri");
		   }
		   if(vali.date){
			   var dateFormat = vali.dateFormat?vali.dateFormat:"yyyy-MM-dd hh:mm:ss";
			   validator.date = {};
			   validator.date.message = $.i18n(validatorErrorPrefix + "date");
			   validator.date.format = dateFormat;
		   }
		   if(vali.stringLength){
			   var min = vali.stringLength[0]?vali.stringLength[0]:1,	max = vali.stringLength[1]?vali.stringLength[1]:vali.stringLength;
			   if(min || max){
				   var stringLength = {};
				   stringLength.max = max;
				   stringLength.min = min;
				   stringLength.message = $.i18n(validatorErrorPrefix + "stringLength", min, max);
				   validator.stringLength = stringLength;
			   }
		   }
		   if(vali.between){
			   var min = vali.between[0]?vali.between[0]:0,	max = vali.between[1]?vali.between[1]:vali.between;
			   if(min || max){
				   var between = {};
				   between.max = max;
				   between.min = min;
				   between.message = $.i18n(validatorErrorPrefix + "between", min, max);
				   validator.between = between;
			   }
		   }
		   if(vali.greaterThan || (vali.number && vali.greaterThan == 0)){
			   var greaterThan = {};
			   greaterThan.value = vali.greaterThan;
			   greaterThan.inclusive = true;
			   greaterThan.message = $.i18n(validatorErrorPrefix + "greaterThan", vali.greaterThan);
			   validator.greaterThan = greaterThan;
		   }
		   if(vali.lessThan){
			   var lessThan = {};
			   lessThan.value = vali.lessThan;
			   lessThan.inclusive = true;
			   lessThan.message = $.i18n(validatorErrorPrefix + "lessThan", vali.lessThan);
			   validator.lessThan = lessThan;
		   }
		   if(vali.lessThan_negative){
			   var lessThan = {};
			   lessThan.value = vali.lessThan_negative;
			   lessThan.inclusive = true;
			   lessThan.message = $.i18n(validatorErrorPrefix + "lessThan", vali.lessThan_negative);
			   validator.lessThan = lessThan;
		   }
		   if((vali.between || vali.numeric || vali.greaterThan || vali.lessThan) && !vali.digitsOne){
			   validator.numeric = {};
			   validator.numeric.message = $.i18n(validatorErrorPrefix + "numeric");
		   }
		   if(vali.digits){
			   validator.digits = {};
			   validator.digits.message = $.i18n(validatorErrorPrefix + "digits");
		   }
		   if(vali.mac){
			   validator.mac = {};
			   validator.mac.message = $.i18n(validatorErrorPrefix + "mac");
		   }
		   if(vali.integer){
			   validator.integer = {};
			   validator.integer.message = $.i18n(validatorErrorPrefix + "integer");
		   }
		   if(vali.digitsOne){
			   validator.digitsOne = {};
			   validator.digitsOne.message = $.i18n(validatorErrorPrefix + "digitsOne");
		   }
		   if(vali.creditCard){
			   validator.creditCard = {};
			   validator.creditCard.message = $.i18n(validatorErrorPrefix + "creditCard");
		   }
		   if(vali.remote){
		   }
		   if(vali.regexp){
			   validator.regexp = {};
			   validator.regexp.regexp = vali.regexp;
			   validator.regexp.message = $.i18n(validatorErrorPrefix + "regexp");
			   if(vali.valiRegexpMsg){
				   validator.regexp.message = $.i18n(vali.valiRegexpMsg);
			   }
		   }
		   if(vali.numbers_regexp){
			   validator.numbers_regexp = {};
			   validator.numbers_regexp.regexp = vali.numbers_regexp;
			   validator.numbers_regexp.message = $.i18n(validatorErrorPrefix + "regexp");
			   if(vali.valiRegexpMsg){
				   validator.numbers_regexp.message = $.i18n(vali.valiRegexpMsg);
			   }
		   }
		   if(vali.decimals){
			   validator.decimals = {};
			   validator.decimals.message = $.i18n(validatorErrorPrefix + "decimals", vali.decimals);
			   validator.decimals.digits = vali.decimals;
		   }
		   if(vali.authNum){
			   validator.authNum = {};
			   var remain = vali.authNum[0]? vali.authNum[0] : 0;
			   var total = vali.authNum[1]? vali.authNum[1] : 0;
			   validator.authNum.message = $.i18n(validatorErrorPrefix + "authNum", remain, total);
