    /**
     * 检查文件大小，配置文件设置文件最大大小 MB
     */  
    function checkfile(fileId, errorTipId){  
    	var maxsize = window.UPLOAD_FILE_MAX_SIZE * 1024 * 1024;
        var errMsg = $.i18n("upload_file_max_size", window.UPLOAD_FILE_MAX_SIZE);  
        var tipMsg = $.i18n("browser_does_not_support_calculating_file_size", window.UPLOAD_FILE_MAX_SIZE);  
        var  browserCfg = {};  
        var ua = window.navigator.userAgent;
        if (ua.indexOf("MSIE")>=1){  
            browserCfg.ie = true;  
        }else if(ua.indexOf("Firefox")>=1){  
            browserCfg.firefox = true;  
        }else if(ua.indexOf("Chrome")>=1){  
            browserCfg.chrome = true;  
        }else if(ua.indexOf("Safari")>=1){  
            browserCfg.safari = true;  
        }
        try{  
            var obj_file = document.getElementById(fileId);  
            if(obj_file.value==""){  
                $("#"+errorTipId).html($.i18n("dynamicImport.pleaseUploadFile")).css('color','#FF3030');
                return false;  
            }  
            var filesize = 0;  
            if(browserCfg.firefox || browserCfg.chrome  || browserCfg.safari ){  
                filesize = obj_file.files[0].size;  
            }else if(browserCfg.ie){  
                var obj_img = document.getElementById(fileId);  
                obj_img.dynsrc=obj_file.value;  
                filesize = obj_img.fileSize;  
            }else{  
            	$("#"+errorTipId).html(tipMsg).css('color','#FF3030');
                return false;  
            }  
            if(filesize==-1){  
            	$("#"+errorTipId).html(tipMsg).css('color','#FF3030');  
                return false;
            }else if(filesize > maxsize){  
            	$("#"+errorTipId).html(errMsg).css('color','#FF3030');
                return false;
            }else{  
            	return true;
            }  
        }catch(e){  
            alert(e);  
        }  
    }
 
	
