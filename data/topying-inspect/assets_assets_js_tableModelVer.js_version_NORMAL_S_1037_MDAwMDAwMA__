  	function Utf8ToUnicode(strUtf8) { 
		  var i,j; 
		  var uCode; 
		  for(i=0,j=0; i<strUtf8.length; i++){ 
	  		  uCode = strUtf8.charCodeAt(i); 
	  		  if(uCode<0x100 || uCode<0x10000){         //ASCII字符 
	  			   j+=2;
	  		  }else if(uCode<0x1000000){ 
	  			   j+=3; 
	  		  }else if(uCode<0x100000000){ 
	  			   j+=4; 
	  		  }else{ 
	  			   break; 
	  		  } 
		  } 
		  return j; 
  	}
