	    const rowLen = rowData.length;
	    const dynamicFileViewLines = data.dynamic_file_view_lines;
	    const maxLine = skipLinesSelVal + dynamicFileViewLines > rowLen ? rowLen : skipLinesSelVal + dynamicFileViewLines;
	    
	    let tableHtml = "<table class='table table-hover table-striped table-bordered table-condensed ";
	    tableHtml += showFieldSelection ? "' id='" + tableId + "-fileTab'>" : "table-preview'>";
	    
	    let cellCnt = 0;
