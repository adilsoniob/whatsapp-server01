   /**
    * 数字格式化
    *
    * @param {Number | String} num 数字
    * @param {String} [separator] 分隔符号，可选参数，默认 英文逗号（,）。
    */
  function numberFormat(num, separator) {
      num = handleInvalidValue(num).toString();

      if (!num) {
          return "";
      }

      separator = separator || ",";

      return num.replace(/\B(?=(\d{3})+(?!\d))/g, separator);
  }

  /**
    * 处理无效的值
    *
    * @param {*} val 要处理的数值
   *
   * @return {*}
    */
  function handleInvalidValue(val) {
      if (val === null || val === undefined || val === "null") {
          return "";
      }
      return val;
  }
  
  /**
   * 创建订单号方法
   * 日期+随机数
   * param randomLen 随机数长度，用以加在时间戳后面
   * ruturn num
   **/
   function random_No(order_prefix, randomLen) {
	   var random_no = "";
	   for (var i = 0; i < randomLen; i++){
	      random_no += Math.floor(Math.random() * 10);
	   }
	   random_no = order_prefix + new Date().format("yyyyMMddHHmmss") + random_no;
	   return random_no;
	}
    
