    function getSearchParams(tableId){
    	var tableItems = getLocalStorageModel(tableId, "tableParams"),
    		columns = tableItems.trs,
    	    params = "{";
    	var tableDefParams = getLocalStorageModel(tableId, "tableDefParams");
    	if(tableDefParams){
	   		 var col = tableDefParams.trs,
	   		 length = col.length;
	   		 for(var j=0; j<length; j++){
	   			 var item = col[j];
	   			 params = advQry(params, col[j].advQry, item.name, item.val);
	   		 }
	   	}
    	if(!columns){
    		return "{}";
    	}
    	var len = columns.length;
    	for(var i=0; i<len; i++){
    		var item = columns[i];
    		if(item.advQry && ((window.search_mode == "top" && (item.topSearch || item.topSearchSet)) || (window.search_mode == "thead" && (item.theadSearchDef || !(item.show === false))))){
    			if(item.timeLimit){
    				var startTimeName = "";
    			    var endTimeName = "";
    			    
    			    if(item.timeLimit){
    			    	var timeLimit = item.timeLimit;
    			    	startTimeName = timeLimit[0];
        			    endTimeName = timeLimit[1];
    			    }
    			    
    			    var beginTimeval = $("#search-"+ tableId + "-"+startTimeName).val();
    				var endTimeval = $("#search-"+ tableId + "-"+endTimeName).val();
    				
    				if(beginTimeval){
    					if(item.dayTimeQuery){
    						beginTimeval += " 00:00:00";
    					}
    					if(item.advQry.length>1){
    						startTimeName = item.name;
    					}
    					params = advQry(params, item.advQry[0], startTimeName, beginTimeval);
    				}
    				if(endTimeval){
    					if(item.dayTimeQuery){
    						endTimeval += " 00:00:00";
    					}
    					params = advQry(params, item.advQry[0], endTimeName, endTimeval);
    				}
    				if(!$(".ui-datepicker-css").is(":hidden")){
    					$(".ui-datepicker-css").css("display","none");
    				}
    				continue;
    			}
    			
    			var val = $("#search-"+ tableId + "-"+ item.name).val();
    			if(val !=0 && !val){
    				continue;
    			}
    			val = encodeURIComponent(val);
    			if(val){
    				if(item.ratio){
    					val = parseFloat(val)*item.ratio;
    					val = parseInt(val);
    				}
    				params +='"cx_LIKE-|-'+ item.name +'":"'+ val +'",';  
    			}
    			var valGte = $("#search-"+ tableId + "-"+ item.name+"-GTE").val();
    			if(valGte){
    				params +='"cx_GTE-|-'+ item.name +'":"'+ valGte +'",';  
    			}
    			var valLte = $("#search-"+ tableId + "-"+ item.name+"-LTE").val();
    			if(valLte){
    				params +='"cx_LTE-|-'+ item.name +'":"'+ valLte +'",';  
    			}
    		}
    	}
    	if(params!='{'){  
        	params = params.substr(0,params.length-1);
        } 
        params += '}'; 
        params = JSON.parse(params);
        queryParamsAddSortParams(tableId, params);
    	return params;
    }
    
    function queryParamsAddSortParams(tableId, params){
    	var MY_ORDER_LIST = getLocalStorageModel(tableId, "sortParams"),
    	    tableItems = getLocalStorageModel(tableId, "tableParams"),
		    order = tableItems.order;
		orderLen = MY_ORDER_LIST.length;
	    if(orderLen>0){  
	    	var html='[';
	    	for(var i=0;i<orderLen;i++){
	    		if(i>0){
	    			html += ',';
	    		}
	    		html+='["' +MY_ORDER_LIST[i][0] +'",' +MY_ORDER_LIST[i][1] +']';
	    	} 
	    	html += ']';
	    	params.cx_ORDER_LIST = html;
	    } 
	    if(!params.cx_ORDER_LIST && order){
	    	params.cx_ORDER_LIST = order;
	    }
    }
    
    function advQry(params, aq, name, val){
    	val = encodeURIComponent(val);
		if(aq == "LIKE"){
			params +='"cx_LIKE-|-'+ name +'":"'+ val +'",';  
		}
		if(aq == "LIKE2"){
			params +='"cx_LIKE2-|-'+ name +'":"'+ val +'",';  
		}
		if(aq == "IN"){
			params +='"cx_IN-|-'+ name +'":"'+ val +'",';  
		}
		if(aq == "GTE"){
			params +='"cx_GTE-|-'+ name +'":"'+ val +'",';  
		}
		if(aq == "LTE"){
			params +='"cx_LTE-|-'+ name +'":"'+ val +'",';  
		}
		return params;
    }

    /**
     * 判断一个字符串是不是时间格式
     */
    function isDate(str){
    	var reg = /^[1-9]\d{3}-(0[1-9]|1[0-2])-(0[1-9]|[1-2][0-9]|3[0-1])\s+(20|21|22|23|[0-1]\d):[0-5]\d:[0-5]\d$/;
    	var regExp = new RegExp(reg);
    	if(!regExp.test(str))
            return false;
        return true;
    }
    
