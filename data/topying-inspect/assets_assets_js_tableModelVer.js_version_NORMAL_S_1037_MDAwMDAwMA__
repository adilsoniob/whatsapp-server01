    /**
     * 输入框年 20被屏蔽掉了，加上来比较
     * @param dt_str
     * @returns {Boolean}
     */
    function datetimeUnderlineDatetimeReg(dt_str){
    	var reg = /((^((1[8-9]\d{2})|([2-9]\d{3}))([-\/\._])(10|12|0?[13578])([-\/\._])(3[01]|[12][0-9]|0?[1-9]) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^((1[8-9]\d{2})|([2-9]\d{3}))([-\/\._])(11|0?[469])([-\/\._])(30|[12][0-9]|0?[1-9]) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^((1[8-9]\d{2})|([2-9]\d{3}))([-\/\._])(0?2)([-\/\._])(2[0-8]|1[0-9]|0?[1-9]) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([2468][048]00)([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([3579][26]00)([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([1][89][0][48])([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([2-9][0-9][0][48])([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([1][89][2468][048])([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([2-9][0-9][2468][048])([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([1][89][13579][26])([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$)|(^([2-9][0-9][13579][26])([-\/\._])(0?2)([-\/\._])(29) (?:(?:[0-2][0-3])|(?:[0-1][0-9])):[0-5][0-9]:[0-5][0-9]$))/;
        var arr_str = dt_str.split(" - ");
        var nowDateTopTwo = getNowDateTopTwo();
        var start_t = nowDateTopTwo + arr_str[0].trim();
        var end_t = nowDateTopTwo + arr_str[1].trim();
        return reg.test(start_t) && reg.test(end_t) && (new Date(start_t) < new Date(end_t));
    }

