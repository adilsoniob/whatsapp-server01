    var calculate_percentage = function(s, f, r){
    	if(!r || !isNumber(r)){
            r = 0;
        }
        if(!s || !isNumber(s) || s == 0){
            return 0;
        }
        if(!f || !isNumber(f)){
            f = 0;
        }
        s = parseInt(s);
        f = parseInt(f);
        r = parseInt(r);
     	return calculatePercentage(s, s+f-r);
    }
    
    
