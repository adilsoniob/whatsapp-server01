  	function calculateSmsCharge(content){
  	   if(!content && content!="0"){
  		   content = "";
  	   }
       var rtn_json = {};
 	   var default_coding = -1;
 	   var len = content.length;
 	   rtn_json.chargeCnt = 1;
 	   rtn_json.con_len = len;
 	   var unicodelen = 0;
 	   var isEn = smsContentIsAscii(content);
 	   rtn_json.isAscii = isEn;
 	   if(isEn){
 		   len = asciiSpecialCharacterLength(content);
 		   rtn_json.con_len = len;
 		   if(0 == default_coding || -1 == default_coding){
 				if(len > 160)
 				{
 					rtn_json.chargeCnt = Math.floor((len+152)/153);
 					return rtn_json;
 				}
 				return rtn_json;
 		   }else{
 				if(len > 140)
 				{
 					rtn_json.chargeCnt = Math.floor((len+133)/134);
 					return rtn_json;
 				}
 				return rtn_json;
 		   }
 		}
 		unicodelen = Utf8ToUnicode(content);
 		if(unicodelen > 140){
 		   rtn_json.chargeCnt = Math.floor((unicodelen+133)/134);
 		}
 		return rtn_json;
    }
  	
  	function asciiSpecialCharacterLength(content){
  		var asciiSpecialCharacterArr = ['0X0C', '0X5E', '0X7B', '0X7D', '0X5C', '0X5B', '0X7E', '0X5D', '0X7C', '0X20AC'];
  		var i,j; 
		for(i=0,j=0; i<content.length; i++){ 
			var str_16 = strToHexCharCode(content[i]);
			if(contains(asciiSpecialCharacterArr, str_16)){
			     j+=2;
			}else{ 
			  j+=1;
			} 
		} 
		return j; 
  	}
  	
  	function smsContentIsAscii(content){
	  	var isEn = true;
	  	for(var i = 0; i < content.length; i++){
	  		if(!isascii(content[i])){
	  			isEn = false;
				break;
	  		}
	  	}
	  	return isEn;
    }
    
  	/**
  	 *  判断字符是否是 ascii码
  	 */
  	function isascii(s){
  		try{
	  		if(lengthInUtf8Bytes(s) == s.length){
	  			return true;
	  		}
  		}catch(e){
  			return false;
  		}
  		return isasciiExtend(s);
  	}
  	
  	function isasciiExtend(str){
  	    //以下特殊字符判断是 ascii码 ，       数组中字符转换后的16进制字符串
  		var e = ['0X00','0X40','0XA3','0X24','0XA5','0XE8','0XE9','0XF9','0XEC','0XF2','0XC7','0X0A','0XD8','0XF8','0X0D','0XC5','0XE5','0X5F','0X0C','0X5E','0X7B','0X7D','0X5C','0X5B','0X7E','0X5D','0X7C','0XC6','0XE6','0XDF','0XC9','0X20','0X21','0X22','0X23','0XA4','0X25','0X26','0X27','0X28','0X29','0X2A','0X2B','0X2C','0X2D','0X2E','0X2F','0X30','0X31','0X32','0X33','0X34','0X35','0X36','0X37','0X38','0X39','0X3A','0X3B','0X3C','0X3D','0X3E','0X3F','0XA1','0X41','0X42','0X43','0X44','0X45','0X46','0X47','0X48','0X49','0X4A','0X4B','0X4C','0X4D','0X4E','0X4F','0X50','0X51','0X52','0X53','0X54','0X55','0X56','0X57','0X58','0X59','0X5A','0XC4','0XD6','0XD1','0XDC','0XA7','0XBF','0X61','0X62','0X63','0X64','0X65','0X66','0X67','0X68','0X69','0X6A','0X6B','0X6C','0X6D','0X6E','0X6F','0X70','0X71','0X72','0X73','0X74','0X75','0X76','0X77','0X78','0X79','0X7A','0XE4','0XF6','0XF1','0XFC','0XE0','0X20AC','0X394','0X3A6','0X393','0X39B','0X3A9','0X3A0','0X3A8','0X3A3','0X398','0X39E'];
  		var str_16 = strToHexCharCode(str);
  	    return contains(e, str_16);
  	}
  	 
  	function contains(arr, val) {
  		val = val.toUpperCase();
  		for (var x = 0; x < arr.length; x++) {
  			var v = arr[x];
  			if (v === val) {
  				return true; 
  			} 
  		}
  		return false;
  	}
  	
  	function lengthInUtf8Bytes(str) {
  		var e_uri_c = encodeURIComponent(str.replace(/%/g, '%25'));
  	    var m = e_uri_c.match(/%[89ABab]/g);
  	    return str.length + (m ? m.length : 0);
  	}
  	
  	function stringToHex(str){
  		var val = "";
  		for(var i =0; i<str.length;i++){
  			if(val == "")
  			   val = str.charCodeAt(i).toString(16);
  			else
  			   val += ","+str.charCodeAt(i).toString(16);
  		}
  		return val;
  	}
  	
