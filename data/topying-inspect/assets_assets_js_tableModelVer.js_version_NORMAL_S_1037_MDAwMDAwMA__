    /**
     * 按指定键对数组对象排序（支持数字/字符串类型）
     * @param {Array} arr - 待排序的对象数组
     * @param {string} key - 排序键（如 "id" "name" "age"）
     * @param {boolean} isAscending - 升序（默认 true）
     * @returns {Array} 排序后的新数组（原数组不变）
     */
    function sortArrayByKey(arr, key, isAscending = true) {
        // 创建新数组避免修改原数据
        const newArr = [...arr];
        
        return newArr.sort((a, b) => {
            const valA = a[key];
            const valB = b[key];

            // 数字类型处理
            if (typeof valA === 'number' && typeof valB === 'number') {
                return isAscending ? valA - valB : valB - valA;
            }
            // 字符串类型处理（区分大小写，按字母顺序）
            if (typeof valA === 'string' && typeof valB === 'string') {
                return isAscending ? valA.localeCompare(valB) : valB.localeCompare(valA);
            }
            // 其他类型统一转为字符串比较（如布尔、日期）
            const strA = String(valA);
            const strB = String(valB);
            return isAscending ? strA.localeCompare(strB) : strB.localeCompare(strA);
        });
    }
    
    
